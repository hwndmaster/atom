<Project>

  <PropertyGroup>
    <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
    <FrameworkPackageVersion>10.0.9</FrameworkPackageVersion>
    <!-- Single source of truth for the Roslyn version: the Atom source
         generators are compiled against Microsoft.CodeAnalysis at this
         version, and every consumer's compiler is pinned to the same
         version via Microsoft.Net.Compilers.Toolset (see Analyzers.props).
         A consumer compiler OLDER than the generator's Roslyn reference
         does not fail the analyzer load - it silently skips the generator
         (warning CS9057) and the build then breaks on missing generated
         members. Keeping both on one property makes that skew impossible. -->
    <RoslynCompilerVersion>5.6.0</RoslynCompilerVersion>
  </PropertyGroup>

  <ItemGroup>
    <!-- Microsoft common dependencies -->
    <PackageVersion Include="System.Reactive" Version="6.1.0" />
    <PackageVersion Include="Microsoft.Extensions.DependencyInjection" Version="$(FrameworkPackageVersion)" />
    <PackageVersion Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="$(FrameworkPackageVersion)"/>
    <PackageVersion Include="Microsoft.Extensions.Logging" Version="$(FrameworkPackageVersion)" />
    <PackageVersion Include="Microsoft.Extensions.Logging.Abstractions" Version="$(FrameworkPackageVersion)" />
    <PackageVersion Include="Microsoft.VisualStudio.Threading" Version="18.7.23" />

    <!-- WPF/UI related dependencies -->
    <PackageVersion Include="DotNetProjects.WpfToolkit.Input" Version="6.1.94" />
    <PackageVersion Include="MahApps.Metro" Version="2.4.11" />
    <PackageVersion Include="ReactiveUI" Version="23.2.28" />
    <PackageVersion Include="ReactiveUI.WPF" Version="23.2.28" />
    <PackageVersion Include="ReactiveUI.Events.WPF" Version="15.1.1" />
    <PackageVersion Include="WpfAnimatedGif" Version="2.0.2" />

    <!-- Entity Framework -->
    <PackageVersion Include="Microsoft.EntityFrameworkCore" Version="$(FrameworkPackageVersion)" />
    <PackageVersion Include="Microsoft.EntityFrameworkCore.InMemory" Version="$(FrameworkPackageVersion)" />
    <PackageVersion Include="Microsoft.EntityFrameworkCore.Sqlite" Version="$(FrameworkPackageVersion)" />
    <PackageVersion Include="Microsoft.EntityFrameworkCore.Tools" Version="$(FrameworkPackageVersion)" />
    <PackageVersion Include="Microsoft.EntityFrameworkCore.Design" Version="$(FrameworkPackageVersion)" />

    <!-- Automated Testing components -->
    <PackageVersion Include="Microsoft.NET.Test.Sdk" Version="18.7.0" />
    <PackageVersion Include="xunit.v3" Version="3.2.2" />
    <PackageVersion Include="xunit.analyzers" Version="1.27.0" />
    <PackageVersion Include="xunit.v3.assert" Version="3.2.2" />
    <PackageVersion Include="xunit.runner.visualstudio" Version="3.1.5" />
    <PackageVersion Include="Xunit.StaFact" Version="3.0.13" />
    <PackageVersion Include="AutoFixture" Version="4.18.1" />
    <PackageVersion Include="AutoFixture.AutoFakeItEasy" Version="4.18.1" />
    <PackageVersion Include="FakeItEasy" Version="9.0.1" />
    <PackageVersion Include="Imposter" Version="0.1.9" />

    <!-- Code analyzers -->
    <PackageVersion Include="Microsoft.Net.Compilers.Toolset" Version="$(RoslynCompilerVersion)" />
    <PackageVersion Include="Microsoft.VisualStudio.Threading.Analyzers" Version="18.7.23" />
    <PackageVersion Include="Roslynator.Analyzers" Version="4.15.0" />
    <PackageVersion Include="SonarAnalyzer.CSharp" Version="10.29.0.143774" />
    <PackageVersion Include="Genius.Atom.Analyzers" Version="0.0.2-beta03" />
  </ItemGroup>
</Project>
