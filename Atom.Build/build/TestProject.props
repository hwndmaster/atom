<Project>

  <ItemGroup Condition="$(IsTestProject) == 'False'">
    <InternalsVisibleTo Include="$(RootNamespace).Tests" />
    <InternalsVisibleTo Include="$(RootNamespace).TestingUtil" />
    <InternalsVisibleTo Include="DynamicProxyGenAssembly2" />
  </ItemGroup>

  <ItemGroup Label="TestUsings" Condition="$(IsTestProject) == 'True' Or $(IsTestingUtilProject) == 'True'">
    <Using Include="AutoFixture" />
    <Using Include="FakeItEasy" />
    <Using Include="Imposter.Abstractions" />
    <Using Include="Xunit" />
  </ItemGroup>
  <ItemGroup Label="TestReferences" Condition="$(IsTestProject) == 'True'">
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit.v3" />
    <PackageReference Include="xunit.analyzers" />
    <PackageReference Include="xunit.runner.visualstudio">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>
  <ItemGroup Label="TestAndTestingUtilsReferences" Condition="$(IsTestProject) == 'True' Or $(IsTestingUtilProject) == 'True'">
    <PackageReference Include="AutoFixture" />
    <PackageReference Include="AutoFixture.AutoFakeItEasy" />
    <PackageReference Include="FakeItEasy" />
    <PackageReference Include="Imposter" />
  </ItemGroup>
  <ItemGroup Label="TestingUtilsReferences" Condition="$(IsTestingUtilProject) == 'True'">
    <PackageReference Include="xunit.v3.assert" />
  </ItemGroup>

</Project>
