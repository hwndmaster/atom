<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <AtomLocation Condition="'$(AtomLocation)' == ''">..\atom\</AtomLocation>
    <AtomGeneratorsFramework>netstandard2.0</AtomGeneratorsFramework>
    <AtomFramework Condition="'$(AtomFramework)' == ''">$(TargetFramework)</AtomFramework>
  </PropertyGroup>

  <ItemGroup Condition="'$(ReferenceAtomData)' == 'true'">
    <Using Include="Genius.Atom.Data" />
  </ItemGroup>

  <ItemGroup Condition="'$(ReferenceAtomDataEf)' == 'true'">
    <Using Include="Genius.Atom.Data.Ef" />
  </ItemGroup>

  <ItemGroup Condition="'$(ReferenceAtomInfrastructure)' == 'true'">
    <Using Include="Genius.Atom.Infrastructure" />
  </ItemGroup>

  <ItemGroup Condition="'$(ReferenceAtomWeb)' == 'true'">
    <Using Include="Genius.Atom.Web" />
  </ItemGroup>

  <Target Name="AtomDataReference" BeforeTargets="PrepareProjectReferences;CollectPackageReferences"
    Condition="'$(ReferenceAtomData)' == 'true'">
    <PropertyGroup>
      <Name>Atom.Data</Name>
      <Path>$(MSBuildThisFileDirectory)$(AtomLocation)$(Name)</Path>
      <ProjectExists Condition="Exists('$(Path)')">true</ProjectExists>
    </PropertyGroup>

    <!-- <Message Text="$(Path)" Importance="High" />
    <Message Text="ProjectExists: $(ProjectExists)" Importance="High" /> -->

    <ItemGroup>
      <Reference Include="Genius.$(Name)" Condition="'$(ProjectExists)' == 'true'">
        <HintPath>$(Path)\bin\Debug\$(AtomFramework)\Genius.$(Name).dll</HintPath>
      </Reference>
      <PackageReference Include="Genius.$(Name)" Condition="'$(ProjectExists)' != 'true'" />

      <!-- Register generator + all its dependencies as Analyzers so Roslyn's isolated load context can resolve them -->
      <Analyzer Include="$(Path).Generators\bin\Debug\$(AtomGeneratorsFramework)\*.dll"
        Condition="'$(ProjectExists)' == 'true'" />
      <PackageReference Include="Genius.$(Name).Generators" Condition="'$(ProjectExists)' != 'true'"
        OutputItemType="Analyzer"
        ReferenceOutputAssembly="false" />
    </ItemGroup>

  </Target>

  <Target Name="AtomDataEfReference" BeforeTargets="PrepareProjectReferences;CollectPackageReferences"
    Condition="'$(ReferenceAtomDataEf)' == 'true'">
    <PropertyGroup>
      <Name>Atom.Data.Ef</Name>
      <Path>$(MSBuildThisFileDirectory)$(AtomLocation)$(Name)</Path>
      <ProjectExists Condition="Exists('$(Path)')">true</ProjectExists>
    </PropertyGroup>

    <!-- <Message Text="$(Path)" Importance="High" />
    <Message Text="ProjectExists: $(ProjectExists)" Importance="High" /> -->

    <ItemGroup>
      <Reference Include="Genius.$(Name)" Condition="'$(ProjectExists)' == 'true'">
        <HintPath>$(Path)\bin\Debug\$(AtomFramework)\Genius.$(Name).dll</HintPath>
      </Reference>
      <PackageReference Include="Genius.$(Name)" Condition="'$(ProjectExists)' != 'true'" />
    </ItemGroup>

    <ItemGroup Condition="$(MSBuildProjectName.EndsWith('.Tests')) Or $(MSBuildProjectName.EndsWith('.TestingUtil'))">
      <Reference Include="Genius.$(Name).TestingUtil" Condition="'$(ProjectExists)' == 'true'">
        <HintPath>$(Path).TestingUtil\bin\Debug\$(AtomFramework)\Genius.$(Name).TestingUtil.dll</HintPath>
      </Reference>
      <PackageReference Include="Genius.$(Name).TestingUtil" Condition="'$(ProjectExists)' != 'true'" />
    </ItemGroup>

  </Target>

  <Target Name="AtomInfrastructureReference" BeforeTargets="PrepareProjectReferences;CollectPackageReferences"
    Condition="'$(ReferenceAtomInfrastructure)' == 'true'">
    <PropertyGroup>
      <Name>Atom.Infrastructure</Name>
      <Path>$(MSBuildThisFileDirectory)$(AtomLocation)$(Name)</Path>
      <ProjectExists Condition="Exists('$(Path)')">true</ProjectExists>
    </PropertyGroup>

    <ItemGroup>
      <Reference Include="Genius.$(Name)" Condition="'$(ProjectExists)' == 'true'">
        <HintPath>$(Path)\bin\Debug\$(AtomFramework)\Genius.$(Name).dll</HintPath>
      </Reference>
      <PackageReference Include="Genius.$(Name)" Condition="'$(ProjectExists)' != 'true'" />
    </ItemGroup>

    <ItemGroup Condition="$(MSBuildProjectName.EndsWith('.Tests')) Or $(MSBuildProjectName.EndsWith('.TestingUtil'))">
      <Reference Include="Genius.$(Name).TestingUtil" Condition="'$(ProjectExists)' == 'true'">
        <HintPath>$(Path).TestingUtil\bin\Debug\$(AtomFramework)\Genius.$(Name).TestingUtil.dll</HintPath>
      </Reference>
      <PackageReference Include="Genius.$(Name).TestingUtil" Condition="'$(ProjectExists)' != 'true'" />
    </ItemGroup>

  </Target>

  <Target Name="AtomUiFormsReference" BeforeTargets="PrepareProjectReferences;CollectPackageReferences"
    Condition="'$(ReferenceAtomUiForms)' == 'true'">
    <PropertyGroup>
      <Name>Atom.UI.Forms</Name>
      <Path>$(MSBuildThisFileDirectory)$(AtomLocation)$(Name)</Path>
      <ProjectExists Condition="Exists('$(Path)')">true</ProjectExists>
    </PropertyGroup>

    <ItemGroup>
      <Reference Include="Genius.$(Name)" Condition="'$(ProjectExists)' == 'true'">
        <HintPath>$(Path)\bin\Debug\$(UiTargetFramework)\Genius.$(Name).dll</HintPath>
      </Reference>
      <PackageReference Include="Genius.$(Name)" Condition="'$(ProjectExists)' != 'true'" />
    </ItemGroup>

    <ItemGroup Condition="$(MSBuildProjectName.EndsWith('.Tests')) Or $(MSBuildProjectName.EndsWith('.TestingUtil'))">
      <Reference Include="Genius.$(Name).TestingUtil" Condition="'$(ProjectExists)' == 'true'">
        <HintPath>$(Path).TestingUtil\bin\Debug\$(UiTargetFramework)\Genius.$(Name).TestingUtil.dll</HintPath>
      </Reference>
      <PackageReference Include="Genius.$(Name).TestingUtil" Condition="'$(ProjectExists)' != 'true'" />
    </ItemGroup>

  </Target>

  <Target Name="AtomWebReference" BeforeTargets="PrepareProjectReferences;CollectPackageReferences"
    Condition="'$(ReferenceAtomWeb)' == 'true'">
    <PropertyGroup>
      <Name>Atom.Web</Name>
      <Path>$(MSBuildThisFileDirectory)$(AtomLocation)$(Name)</Path>
      <ProjectExists Condition="Exists('$(Path)')">true</ProjectExists>
    </PropertyGroup>

    <ItemGroup>
      <Reference Include="Genius.$(Name)" Condition="'$(ProjectExists)' == 'true'">
        <HintPath>$(Path)\bin\Debug\$(AtomFramework)\Genius.$(Name).dll</HintPath>
      </Reference>
      <PackageReference Include="Genius.$(Name)" Condition="'$(ProjectExists)' != 'true'" />
    </ItemGroup>

  </Target>

  <!-- Copies the locally built Atom assemblies and their 3rd-party dependencies into the output
       folder AFTER the standard build copy. A transitive Genius.Atom.* NuGet package (pinned to an
       older AtomPackageVersion) can otherwise place a stale copy of e.g. Genius.Atom.Infrastructure
       into the output, which then fails to load next to locally built assemblies of a newer version.
       Running after CopyFilesToOutputDirectory ensures the locally built DLLs always win. -->
  <Target Name="AtomCopyLocalDependencies" AfterTargets="CopyFilesToOutputDirectory">
    <ItemGroup>
      <_AtomLocalDependencyDlls Include="$(MSBuildThisFileDirectory)$(AtomLocation)Atom.Infrastructure\bin\Debug\$(AtomFramework)\*.dll"
        Condition="'$(ReferenceAtomInfrastructure)' == 'true' And Exists('$(MSBuildThisFileDirectory)$(AtomLocation)Atom.Infrastructure')" />
      <_AtomLocalDependencyDlls Include="$(MSBuildThisFileDirectory)$(AtomLocation)Atom.Data.Ef\bin\Debug\$(AtomFramework)\*.dll"
        Condition="'$(ReferenceAtomDataEf)' == 'true' And Exists('$(MSBuildThisFileDirectory)$(AtomLocation)Atom.Data.Ef')" />
      <_AtomLocalDependencyDlls Include="$(MSBuildThisFileDirectory)$(AtomLocation)Atom.UI.Forms\bin\Debug\$(UiTargetFramework)\*.dll"
        Condition="'$(ReferenceAtomUiForms)' == 'true' And Exists('$(MSBuildThisFileDirectory)$(AtomLocation)Atom.UI.Forms')" />
    </ItemGroup>

    <Copy SourceFiles="@(_AtomLocalDependencyDlls)" DestinationFolder="$(TargetDir)\" SkipUnchangedFiles="true" />
  </Target>
</Project>
